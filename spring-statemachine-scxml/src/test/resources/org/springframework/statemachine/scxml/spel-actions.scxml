<?xml version="1.0" encoding="UTF-8"?>
<scxml xmlns="http://www.w3.org/2005/07/scxml" version="1.0" initial="S1">
  <state id="S1">
    <transition event="E1" target="S2"/>
  </state>
  <state id="S2">
    <onentry>
      <log expr="extendedState.variables.put('spelVar', 'spelValue')"/>
    </onentry>
  </state>
