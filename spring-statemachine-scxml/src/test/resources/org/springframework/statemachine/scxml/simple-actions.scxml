<?xml version="1.0" encoding="UTF-8"?>
<scxml xmlns="http://www.w3.org/2005/07/scxml" version="1.0" initial="S1">
  <state id="S1">
    <onentry>
      <action bean="action1"/>
    </onentry>
    <transition event="E1" target="S2"/>
  </state>
  <state id="S2">
    <onexit>
      <log expr="'Exiting S2'"/>
    </onexit>
  </state>
</scxml>

